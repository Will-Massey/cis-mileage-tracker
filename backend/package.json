{
  "name": "mileage-tracker-api",
  "version": "1.0.0",
  "description": "UK Business Mileage Tracking API - HMRC Compliant",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate --schema=src/models/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/models/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/models/prisma/schema.prisma",
    "prisma:seed": "node src/models/prisma/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "prisma": {
    "schema": "src/models/prisma/schema.prisma"
  },
  "keywords": [
    "mileage",
    "hmrc",
    "uk",
    "business",
    "expenses",
    "cis"
  ],
  "author": "Mileage Tracker Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fast-csv": "^4.3.6",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
