# ============================================
# UK Business Mileage Tracker - Environment Variables
# ============================================

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ============================================
# Database Configuration (SQLite for local dev)
# ============================================
DATABASE_URL="file:./dev.db"
DATABASE_SSL=false

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-dev-only
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long-dev-only
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# Password Security
# ============================================
BCRYPT_ROUNDS=10

# ============================================
# Email Configuration (SMTP)
# ============================================
EMAIL_FROM=noreply@mileagetracker.co.uk
EMAIL_FROM_NAME=Mileage Tracker
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# HMRC Configuration
# ============================================
HMRC_RATE_FIRST_10000=0.45
HMRC_RATE_OVER_10000=0.25
CURRENT_TAX_YEAR=2024-25

# ============================================
# Report Generation
# ============================================
REPORT_EXPIRY_DAYS=30
MAX_REPORT_SIZE_MB=10
REPORTS_DIR=./reports

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:5173

# ============================================
# Security Headers
# ============================================
HELMET_ENABLED=true

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
